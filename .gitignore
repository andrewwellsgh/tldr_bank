# Custom .gitignore for Python projects
.custom_group_settings
.custom_spoof_settings
.hide_custom_settings

#Ignore any content in files
/csv_input/*
/settings_store/*
/csv_store/*

#Ignore bundled code
bundle.txt

# To Do list
to do.txt

# Gitkeep Files (avoids folders being ignored if empty)
!csv_input/.gitkeep
!settings/.gitkeep
!csv_store/.gitkeep

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv/
venv/

# Poetry lock file if you don't want to commit
# (usually you DO want to commit poetry.lock)
# poetry.lock

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE / editor folders
.vscode/
.idea/