# Custom .gitignore for Python projects
/csv_input*
exporter.py
project_export.txt
setup_tldr_bank.sh
update_readme.sh
upgrade_tldr_bank.sh

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv/
venv/

# Poetry lock file if you don't want to commit
# (usually you DO want to commit poetry.lock)
# poetry.lock

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE / editor folders
.vscode/
.idea/